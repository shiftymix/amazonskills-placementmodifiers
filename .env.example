# Amazon Ads API Credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Get CLIENT_ID and CLIENT_SECRET from:
#   https://advertising.amazon.com/API/access
#
# Then run: python run.py auth
# to complete OAuth and auto-populate ADS_REFRESH_TOKEN.

ADS_CLIENT_ID=amzn1.application-oa2-client.REPLACE_ME
ADS_CLIENT_SECRET=REPLACE_ME
ADS_REFRESH_TOKEN=
